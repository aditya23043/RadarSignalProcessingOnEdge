    status = XAxiDma_ReadReg(XPAR_AXI_DMA_1_BASEADDR, 0x04) & 0x00000002;
    while (status != 0x00000002)
    {
        status = XAxiDma_ReadReg(XPAR_AXI_DMA_1_BASEADDR, 0x04) & 0x00000002;
    }

    printf("7\n");

    // S2MM
    status = XAxiDma_ReadReg(XPAR_AXI_DMA_1_BASEADDR, 0x34) & 0x00000002;
    while (status != 0x00000002)
    {
        status = XAxiDma_ReadReg(XPAR_AXI_DMA_1_BASEADDR, 0x34) & 0x00000002;
    }

    printf("8\n");

    XTime_GetTime(&pl_end);

    printf("9\n");

    Xil_DCacheInvalidateRange((UINTPTR)output, sizeof(output));

    /* >>> */

    printf("DMA Done\n");

    for(int i = 0; i < N; i++)
    {
        printf("%f + (%f*I), ", crealf(output[i]), cimagf(output[i]));
    }
    printf("\n");

    printf("\nPL: %f us\n", (float)1.0 * (pl_end - pl_start) / (COUNTS_PER_SECOND / 1000000));
}

int main(void)
{
    init_platform();

    foo();

    cleanup_platform();
    return 0;
}

